generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  phone     String?
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Role relationship
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  // Profile relationships
  patient Patient?
  doctor  Doctor?
  staff   Staff?

  // Admin actions
  createdBlogs      BlogPost[]
  createdTreatments Treatment[]
  createdProducts   Product[]
  uploadedMedia     Media[]
  auditLogs         AuditLog[]

  notifications Notification[]

  @@map("users")
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  users User[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  resource    String
  action      String
  description String?

  roles Role[]

  @@map("permissions")
}

// ============================================
// PATIENT MANAGEMENT
// ============================================

model Patient {
  id                 String    @id @default(uuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateOfBirth        DateTime?
  gender             Gender?
  bloodGroup         String?
  address            String?
  city               String?
  state              String?
  country            String?
  pincode            String?
  emergencyContact   String?
  medicalHistory     String?
  allergies          String?
  currentMedications String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relationships
  appointments     Appointment[]
  prescriptions    Prescription[]
  medicalRecords   MedicalRecord[]
  treatmentHistory PatientTreatment[]

  @@map("patients")
}

model Doctor {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialization  String
  qualifications  String
  experience      Int // years
  licenseNumber   String?
  biography       String?
  isAvailable     Boolean  @default(true)
  consultationFee Decimal?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relationships
  treatments    Treatment[]
  appointments  Appointment[]
  timeSlots     DoctorTimeSlot[]
  prescriptions Prescription[]

  @@map("doctors")
}

model Staff {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  department  String
  position    String
  joiningDate DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("staff")
}

// ============================================
// TREATMENTS & SERVICES
// ============================================

model TreatmentCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  slug        String   @unique
  image       String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  treatments Treatment[]

  @@map("treatment_categories")
}

model Treatment {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  description   String
  benefits      String[]
  duration      Int // in minutes
  price         Decimal  @db.Decimal(10, 2)
  discountPrice Decimal? @db.Decimal(10, 2)

  // Content
  shortDescription String?
  fullDescription  String?
  procedure        String?
  afterCare        String?

  // Media
  featuredImage String?
  gallery       String[]

  // SEO
  metaTitle       String?
  metaDescription String?
  keywords        String[]

  // Status
  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)
  sortOrder  Int     @default(0)

  // Relationships
  categoryId String?
  category   TreatmentCategory? @relation(fields: [categoryId], references: [id])

  doctorId String?
  doctor   Doctor? @relation(fields: [doctorId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  appointments      Appointment[]
  patientTreatments PatientTreatment[]

  @@map("treatments")
}

model PatientTreatment {
  id          String          @id @default(uuid())
  patientId   String
  patient     Patient         @relation(fields: [patientId], references: [id])
  treatmentId String
  treatment   Treatment       @relation(fields: [treatmentId], references: [id])
  startDate   DateTime
  endDate     DateTime?
  sessions    Int             @default(1)
  notes       String?
  status      TreatmentStatus @default(ONGOING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("patient_treatments")
}

// ============================================
// PRODUCTS
// ============================================

model ProductCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  slug        String   @unique
  image       String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("product_categories")
}

model Product {
  id               String  @id @default(uuid())
  name             String
  slug             String  @unique
  description      String
  shortDescription String?

  // Pricing
  price         Decimal  @db.Decimal(10, 2)
  discountPrice Decimal? @db.Decimal(10, 2)
  costPrice     Decimal? @db.Decimal(10, 2)

  // Inventory
  sku               String? @unique
  stock             Int     @default(0)
  lowStockThreshold Int     @default(10)
  trackInventory    Boolean @default(true)

  // Media
  featuredImage String?
  gallery       String[]

  // SEO
  metaTitle       String?
  metaDescription String?
  keywords        String[]

  // Status
  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)
  sortOrder  Int     @default(0)

  // Relationships
  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

// ============================================
// APPOINTMENTS
// ============================================

model Appointment {
  id String @id @default(uuid())

  // Patient
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  // Doctor
  doctorId String
  doctor   Doctor @relation(fields: [doctorId], references: [id])

  // Treatment
  treatmentId String
  treatment   Treatment @relation(fields: [treatmentId], references: [id])

  // Scheduling
  date       DateTime
  startTime  String // HH:MM format
  endTime    String // HH:MM format
  timeSlotId String?

  // Details
  notes    String?
  symptoms String?
  status   AppointmentStatus @default(PENDING)
  type     AppointmentType   @default(IN_PERSON)

  // Payment
  paymentStatus PaymentStatus @default(PENDING)
  amount        Decimal?      @db.Decimal(10, 2)

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  confirmedAt DateTime?
  cancelledAt DateTime?
  completedAt DateTime?

  // Relations
  prescriptions  Prescription[]
  medicalRecords MedicalRecord[]

  @@index([patientId, date])
  @@index([doctorId, date])
  @@index([status])
  @@map("appointments")
}

model DoctorTimeSlot {
  id        String   @id @default(uuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  dayOfWeek Int // 0 = Sunday, 1 = Monday, etc.
  startTime String // HH:MM format
  endTime   String // HH:MM format
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([doctorId, dayOfWeek, startTime])
  @@map("doctor_time_slots")
}

// ============================================
// MEDICAL RECORDS
// ============================================

model Prescription {
  id            String       @id @default(uuid())
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        Doctor       @relation(fields: [doctorId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  prescriptionDate DateTime @default(now())
  diagnosis        String
  symptoms         String?
  notes            String?

  // Medications stored as JSON
  medications Json

  // Files
  attachments String[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("prescriptions")
}

model MedicalRecord {
  id            String       @id @default(uuid())
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  recordType  RecordType
  title       String
  description String?

  // Files
  files String[]

  // Vitals (if applicable)
  vitals Json?

  notes      String?
  recordedBy String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("medical_records")
}

// ============================================
// BLOG & CONTENT
// ============================================

model BlogCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts BlogPost[]

  @@map("blog_categories")
}

model BlogPost {
  id      String  @id @default(uuid())
  title   String
  slug    String  @unique
  excerpt String?
  content String  @db.Text

  // Media
  featuredImage String?

  // SEO
  metaTitle       String?
  metaDescription String?
  keywords        String[]

  // Publishing
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?
  isFeatured  Boolean    @default(false)
  viewCount   Int        @default(0)

  // Relationships
  categoryId String?
  category   BlogCategory? @relation(fields: [categoryId], references: [id])

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  tags      BlogTag[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("blog_posts")
}

model BlogTag {
  id        String     @id @default(uuid())
  name      String     @unique
  slug      String     @unique
  posts     BlogPost[]
  createdAt DateTime   @default(now())

  @@map("blog_tags")
}

// ============================================
// CMS (Content Management System)
// ============================================

model CmsPage {
  id          String  @id @default(uuid())
  title       String
  slug        String  @unique
  description String?

  // SEO
  metaTitle       String?
  metaDescription String?
  keywords        String[]

  // Status
  isActive  Boolean @default(true)
  showInNav Boolean @default(false)
  sortOrder Int     @default(0)

  // Sections
  sections CmsSection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cms_pages")
}

model CmsSection {
  id     String  @id @default(uuid())
  pageId String
  page   CmsPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  name String
  type SectionType

  // Content stored as JSON for flexibility
  content Json

  // Styling
  styles Json?

  // Layout
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cms_sections")
}

// ============================================
// MEDIA & GALLERY
// ============================================

model Media {
  id           String  @id @default(uuid())
  filename     String
  originalName String
  mimeType     String
  size         Int // in bytes
  url          String
  thumbnailUrl String?

  // Organization
  folder  String  @default("general")
  altText String?
  caption String?

  // Metadata
  width    Int?
  height   Int?
  duration Int? // for videos

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("media")
}

model Gallery {
  id          String          @id @default(uuid())
  title       String
  description String?
  category    GalleryCategory @default(CLINIC)

  // Images
  images GalleryImage[]

  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("galleries")
}

model GalleryImage {
  id        String  @id @default(uuid())
  galleryId String
  gallery   Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  url          String
  thumbnailUrl String?
  caption      String?
  sortOrder    Int     @default(0)

  createdAt DateTime @default(now())

  @@map("gallery_images")
}

// ============================================
// TESTIMONIALS
// ============================================

model Testimonial {
  id      String  @id @default(uuid())
  name    String
  avatar  String?
  role    String?
  rating  Int     @default(5)
  content String

  // Optional patient relation
  patientId String?

  // Status
  isApproved Boolean @default(false)
  isFeatured Boolean @default(false)
  sortOrder  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonials")
}

// ============================================
// NOTIFICATIONS & COMMUNICATION
// ============================================

model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title   String
  message String
  type    NotificationType

  // Link to related entity
  entityType String?
  entityId   String?

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

// ============================================
// SETTINGS & CONFIGURATION
// ============================================

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
  type  String @default("string") // string, number, boolean, json
  group String @default("general")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ============================================
// AUDIT LOGS
// ============================================

model AuditLog {
  id     String  @id @default(uuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action     String // CREATE, UPDATE, DELETE, LOGIN, etc.
  entityType String // User, Patient, Appointment, etc.
  entityId   String?

  oldValues Json?
  newValues Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ============================================
// ENUMS
// ============================================

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum TreatmentStatus {
  PLANNED
  ONGOING
  COMPLETED
  CANCELLED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentType {
  IN_PERSON
  ONLINE
  PHONE
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  REFUNDED
  FAILED
}

enum RecordType {
  LAB_REPORT
  DIAGNOSIS
  TREATMENT_NOTE
  PROGRESS_NOTE
  REFERRAL
  OTHER
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SectionType {
  HERO
  TEXT
  IMAGE
  VIDEO
  GALLERY
  TESTIMONIALS
  FEATURES
  TREATMENTS
  PRODUCTS
  BLOG
  TEAM
  CONTACT_FORM
  CUSTOM
}

enum GalleryCategory {
  CLINIC
  TREATMENTS
  EVENTS
  TRANSFORMATIONS
  FACILITIES
}

enum NotificationType {
  APPOINTMENT
  PRESCRIPTION
  SYSTEM
  REMINDER
  PROMOTION
}
